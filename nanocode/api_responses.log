,{"role":"tool","tool_call_id":"call_5ffee33c9b364f31a18d801f","content":"   1| import { readdir, stat, appendFile } from \"node:fs/promises\";\n   2| import { join } from \"node:path\";\n   3| import { z } from \"zod\";\n   4| \n   5| type ToolDef = {\n   6|     description: string;\n   7|     params: Record<string, string>;\n   8|     handler: (args: any) => Promise<any>;\n   9| };\n  10| \n  11| const toolsDef: Record<string, ToolDef> = {\n  12|     read: {\n  13|         description: \"read a file with optional offset and limit\",\n  14|         params: {\n  15|             path: \"string\",\n  16|             offset: \"number?\",\n  17|             limit: \"number?\"\n  18|         },\n  19|         handler: async (args: { path: string, offset?: number, limit?: number }) => {\n  20|             const { path } = args;\n  21|             const offset = args.offset ?? 0;\n  22|             const limit = args.limit;\n  23| \n  24|             const content = await Bun.file(path).text();\n  25|             const lines = content.split(\"\\n\");\n  26| \n  27|             const end = limit ? offset + limit : lines.length;\n  28|             const selected = lines.slice(offset, end);\n  29| \n  30|             return selected.map((line, idx) => {\n  31|                 const lineNum = (offset + idx + 1).toString().padStart(4, \" \");\n  32|                 return `${lineNum}| ${line}`;\n  33|             }).join(\"\\n\");\n  34|         }\n  35|     },\n  36|     write: {\n  37|         description: \"write a file\",\n  38|         params: {\n  39|             path: \"string\",\n  40|             content: \"string\"\n  41|         },\n  42|         handler: async (args: { path: string, content: string }) => {\n  43|             await Bun.write(args.path, args.content);\n  44|             return \"ok\";\n  45|         }\n  46|     },\n  47|     edit: {\n  48|         description: \"edit a file by replacing a string\",\n  49|         params: {\n  50|             path: \"