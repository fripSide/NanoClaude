sFile()) {\n 100|                         files.push({ path: file, mtime: stats.mtimeMs });\n 101|                     }\n 102|                 } catch (e) {\n 103|                     // ignore\n 104|                 }\n 105|             }\n 106| \n 107|             files.sort((a, b) => b.mtime - a.mtime);\n 108| \n 109|             return files.map(f => f.path).join(\"\\n\") || \"none\";\n 110|         }\n 111|     },\n 112|     grep: {\n 113|         description: \"grep files in a directory\",\n 114|         params: {\n 115|             path: \"string?\",\n 116|             pat: \"string\"\n 117|         },\n 118|         handler: async (args: { path?: string, pat: string }) => {\n 119|             const pattern = args.pat;\n 120|             const regex = new RegExp(pattern);\n 121|             const hits: string[] = [];\n 122|             const searchDir = args.path || \".\";\n 123|             const glob = new Bun.Glob(\"**/*\");\n 124| \n 125|             for await (const file of glob.scan({ cwd: searchDir })) {\n 126|                 try {\n 127|                     const fullPath = join(searchDir, file);\n 128|                     const stats = await stat(fullPath);\n 129|                     if (!stats.isFile()) continue;\n 130| \n 131|                     const content = await Bun.file(fullPath).text();\n 132|                     const lines = content.split(\"\\n\");\n 133| \n 134|                     for (let i = 0; i < lines.length; i++) {\n 135|                         if (regex.test(lines[i])) {\n 136|                             hits.push(`${fullPath}:${i + 1}:${lines[i].trimEnd()}`);\n 137|                         }\n 138|                     }\n 139|                     if (hits.length >= 50) break;\n 140|                 } catch (e) {\n 141|                     // ignore\n 142|                 }\n 143|             }\n 144| \n 145|             return hits.slice(0, 50).join(\"\\n\") || \"none\";\n 146|         }\n 147|     },\n 148|     bash: {\n 149|         description: \"run a bash command with timeout\",\n 150|         params: {\n 151|             cmd: \"string\"\n 152|         },\n 153|         handler: async (args: { cmd: string }) => {\n 154|             const command = args.cmd;\n 155|             const proc = Bun.spawn([\"bash\", \"-c\", command], {\n 156|                 stdout: \"pipe\",\n 157|                 stderr: \"pipe\",\n 158|             });\n 159| \n 160|             const timeoutSignal = AbortSignal.timeout(30000);\n 161|             let output = \"\";\n 162|             let timer: ReturnType<typeof setTimeout> | null = null;\n 163| \n 164|             try {\n 165|                 const exitPromise = proc.exited;\n 166|                 const timeoutPromise = new Promise<void>((_, reject) => {\n 167|                     timer = setTimeout(() => {\n 168|                         proc.kill();\n 169|                         reject(new Error(\"Timeout\"));\n 170|                     }, 30000);\n 171|                 });\n 172| \n 173|                 const readStream = async (reader: ReadableStreamDefaultReader<Uint8Array>) => {\n 174|                     try {\n 175|                         while (true) {\n 176|                             const { done, value } = await reader.read();\n 177|                             if (done) break;\n 178|                             const chunk = new TextDecoder().decode(value);\n 179|                             output += chunk;\n 180|                         }\n 181|                     } finally {\n 182|                         reader.releaseLock();\n 183|                     }\n 184|                 };\n 185| \n 186|                 await Promise.all([\n 187|                     readStream(proc.stdout.getReader()),\n 188|                     readStream(proc.stderr.getReader()),\n 189|                     Promise.race([exitPromise, timeoutPromise])\n 190|                 ]);\n 191| \n 192|             } catch (e) {\n 193|                 output += \"\\n(timed out after 30s)\";\n 194|             } finally {\n 195|                 if (timer) clearTimeout(timer);\n 196|             }\n 197| \n 198|             return output.trim() || \"(empty)\";\n 199|         }\n 200|     },\n 201| \n 202| };\n 203| \n 204| function mapTypeToZod(typeStr: string) {\n 205|     const isOptional = typeStr.endsWith(\"?\");\n 206|     const baseType = typeStr.replace(\"?\", \"\");\n 207| \n 208|     let schema: z.ZodType<any>;\n 209|     switch (baseType) {\n 210|         case \"string\": schema = z.string(); break;\n 211|         case \"number\": schema = z.number(); break;\n 212|         case \"boolean\": schema = z.boolean(); break;\n 213|         default: schema = z.any();\n 214|     }\n 215| \n 216|     if (isOptional) {\n 217|         schema = schema.optional();\n 218|     }\n 219|     return schema;\n 220| }\n 221| \n 222| const toolSchemas = Object.entries(toolsDef).reduce((acc, [name, def]) => {\n 223|     const shape: Record<string, z.ZodType<any>> = {};\n 224|     for (const [key, type] of Object.entries(def.params)) {\n 225|         shape[key] = mapTypeToZod(type);\n 226|     }\n 227|     acc[name] = z.object(shape);\n 228|     return acc;\n 229| }, {} as Record<string, z.ZodObject<any>>);\n 230| \n 231| export async function runTool(name: string, args: any) {\n 232|     const def = toolsDef[name];\n 233|     if (!def) {\n 234|         throw new Error(`Tool not found: ${name}`);\n 235|     }\n 236| \n 237|     const schema = toolSchemas[name];\n 238|     const validatedArgs = schema.parse(args);\n 239|     return def.handler(validatedArgs);\n 240| }\n 241| \n 242| export function makeSchema() {\n 243|     const result = [];\n 244|     for (const [name, def] of Object.entries(toolsDef)) {\n 245|         const properties: Record<string, { type: string }> = {};\n 246|         const required: string[] = [];\n 247| \n 248|         for (const [paramName, paramType] of Object.entries(def.params)) {\n 249|             const isOptional = paramType.endsWith(\"?\");\n 250|             const baseType = paramType.replace(\"?\", \"\");\n 251| \n 252|             // Map TypeScript types to JSON schema types\n 253|             const jsonType = baseType === \"number\" ? \"integer\" : baseType;\n 254| \n 255|             properties[paramName] = { type: jsonType };\n 256|             if (!isOptional) {\n 257|                 required.push(paramName);\n 258|             }\n 259|         }\n 260| \n 261|         result.push({\n 262|             name,\n 263|             description: def.description,\n 264|             input_schema: {\n 265|                 type: \"object\",\n 266|                 properties,\n 267|                 required\n 268|             }\n 269|         });\n 270|     }\n 271|     return result;\n 272| }\n 273| \n 274| \n 275| // --- Agentic Loop Implementation ---\n 276| \n 277| import { createInterface } from \"node:readline/promises\";\n 278| \n 279| const OPENROUTER_KEY = process.env.OPENROUTER_API_KEY;\n 280| const API_URL = process.env.API_URL;\n 281| const MODEL = process.env.MODEL;\n 282| \n 283| // ANSI colors\n 284| const RESET = \"\\x1b[0m\";\n 285| const BOLD = \"\\x1b[1m\";\n 286| const DIM = \"\\x1b[2m\";\n 287| const BLUE = \"\\x1b[34m\";\n 288| const CYAN = \"\\x1b[36m\";\n 289| const GREEN = \"\\x1b[32m\";\n 290| const YELLOW = \"\\x1b[33m\";\n 291| const RED = \"\\x1b[31m\";\n 292| \n 293| function renderMarkdown(text: string): string {\n 294|     return text.replace(/\\*\\*(.+?)\\*\\*/g, `${BOLD}$1${RESET}`);\n 295| }\n 296| \n 297| function separator() {\n 298|     return `${DIM}${\"─\".repeat(Math.min(process.stdout.columns || 80, 80))}${RESET}`;\n 299| }\n 300| \n 301| \n 302| const stats = {\n 303|     requests: 0,\n 304|     tools: {} as Record<string, number>,\n 305|     logs: [] as string[]\n 306| };\n 307| \n 308| async function callApi(messages: any[], systemPrompt: string) {\n 309|     stats.requests++;\n 310|     const headers: Record<string, string> = {\n 311|         \"Content-Type\": \"application/json\",\n 312|         \"Authorization\": `Bearer ${process.env.OPENROUTER_KEY || process.env.OPENROUTER_API_KEY || \"\"}`,\n 313|     };\n 314| \n 315|     let url = API_URL;\n 316|     if (!url) throw new Error(\"API_URL is undefined\");\n 317| \n 318|     if (!url.endsWith(\"/chat/completions\")) {\n 319|         url = url.endsWith(\"/\") ? `${url}chat/completions` : `${url}/chat/completions`;\n 320|     }\n 321| \n 322|     const tools = makeSchema().map(tool => ({\n 323|         type: \"function\",\n 324|         function: {\n 325|             name: tool.name,\n 326|             description: tool.description,\n 327|             parameters: tool.input_schema\n 328|         }\n 329|     }));\n 330| \n 331|     // Convert internal message format to OpenAI format\n 332|     const convertedMessages: any[] = [\n 333|         { role: \"system\", content: systemPrompt },\n 334|     ];\n 335| \n 336|     for (const msg of messages) {\n 337|         if (msg.role === \"user\" && Array.isArray(msg.content) && msg.content[0]?.type === \"tool_result\") {\n 338|             for (const res of msg.content) {\n 339|                 convertedMessages.push({\n 340|                     role: \"tool\",\n 341|                     tool_call_id: res.tool_use_id,\n 342|                     content: res.content\n 343|                 });\n 344|             }\n 345|         } else if (msg.role === \"assistant\" && Array.isArray(msg.content)) {\n 346|             const textParts = msg.content.filter((c: any) => c.type === \"text\").map((c: any) => c.text).join(\"\\n\");\n 347|             const toolCalls = msg.content.filter((c: any) => c.type === \"tool_use\").map((c: any) => ({\n 348|                 id: c.id,\n 349|                 type: \"function\",\n 350|                 function: {\n 351|                     name: c.name,\n 352|                     arguments: JSON.stringify(c.input)\n 353|                 }\n 354|             }));\n 355| \n 356|             const asstMsg: any = { role: \"assistant\" };\n 357|             if (textParts) asstMsg.content = textParts;\n 358|             if (toolCalls.length > 0) asstMsg.tool_calls = toolCalls;\n 359|             convertedMessages.push(asstMsg);\n 360|         } else {\n 361|             convertedMessages.push({ role: msg.role, content: typeof msg.content === 'string' ? msg.content : JSON.stringify(msg.content) });\n 362|         }\n 363|     }\n 364| \n 365|     const body = {\n 366|         model: MODEL,\n 367|         messages: convertedMessages,\n 368|         tools,\n 369|     };\n 370| \n 371|     await appendFile(\"api_responses.log\", `[Request] ${new Date().toISOString()}\\n${JSON.stringify(body)}\\n\\n`);\n 372| \n 373|     const controller = new AbortController();\n 374|     const timeout = setTimeout(() => controller.abort(), 60000);\n 375| \n 376|     try {\n 377|         const response = await fetch(url, {\n 378|             method: \"POST\",\n 379|             headers,\n 380|             body: JSON.stringify(body),\n 381|             signal: controller.signal\n 382|         });\n 383| \n 384|         if (!response.ok) {\n 385|             throw new Error(`API Error: ${response.status} ${response.statusText} - ${await response.text()}`);\n 386|         }\n 387| \n 388|         const data = await response.json();\n 389|         await appendFile(\"api_responses.log\", `[Response] ${new Date().toISOString()}\\n${JSON.stringify(data)}\\n\\n---\\n\\n`);\n 390| \n 391|         // Convert OpenAI response to internal format\n 392|         const choice = data.choices[0];\n 393|         const msg = choice.message;\n 394|         const content: any[] = [];\n 395| \n 396|         if (msg.content) {\n 397|             content.push({ type: \"text\", text: msg.content });\n 398|         }\n 399|         if (msg.tool_calls) {\n 400|             for (const call of msg.tool_calls) {\n 401|                 content.push({\n 402|                     type: \"tool_use\",\n 403|                     id: call.id,\n 404|                     name: call.function.name,\n 405|                     input: JSON.parse(call.function.arguments)\n 406|                 });\n 407|             }\n 408|         }\n 409|         return { content };\n 410|     } finally {\n 411|         clearTimeout(timeout);\n 412|     }\n 413| }\n 414| \n 415| async function main() {\n 416|     console.log(`${BOLD}nanocode${RESET} | ${DIM}${MODEL} | ${process.cwd()}${RESET}\\n`);\n 417| \n 418|     let messages: any[] = [];\n 419|     const systemPrompt = `Concise coding assistant. cwd: ${process.cwd()}`;\n 420|     // Helper for reading input\n 421|     console.log(separator());\n 422| \n 423|     while (true) {\n 424|         process.stdout.write(`${BOLD}${BLUE}❯${RESET} `);\n 425|         // prompt() is a global in Bun (synchronous)\n 426|         const userInput = prompt(\"\");\n 427|         console.log(separator());\n 428| \n 429|         if (!userInput) continue;\n 430| \n 431|         const input = userInput.trim();\n 432| \n 433|         // Log user input\n 434|         const userSummary = `${new Date().toISOString()} | USER | ${input}`;\n 435|         stats.logs.push(userSummary);\n 436|         await appendFile(\"actions.log\", userSummary + \"\\n\");\n 437| \n 438|         if ([\"/q\", \"exit\"].includes(input)) {\n 439|             break;\n 440|         }\n 441| \n 442|         if (input.startsWith(\"/stats\")) {\n 443|             const parts = input.split(\" \");\n 444|             const path = parts[1];\n 445|             const content = [\n 446|                 `Total Requests: ${stats.requests}`,\n 447|                 `Tool Usage:`,\n 448|                 ...Object.entries(stats.tools).map(([name, count]) => `  - ${name}: ${count}`),\n 449|                 `Logs:`,\n 450|                 ...stats.logs\n 451|             ].join(\"\\n\");\n 452| \n 453|             if (path) {\n 454|                 await Bun.write(path, content);\n 455|                 console.log(`${GREEN}⏺ Stats saved to ${path}${RESET}`);\n 456|             } else {\n 457|                 console.log(`${CYAN}Stats:${RESET}\\n${content}`);\n 458|             }\n 459|             continue;\n 460|         }\n 461| \n 462|         if (input === \"/c\") {\n 463|             messages = [];\n 464|             console.log(`${GREEN}⏺ Cleared conversation${RESET}`);\n 465|             continue;\n 466|         }\n 467| \n 468|         messages.push({ role: \"user\", content: input });\n 469|         // console.error(`DEBUG: Processing input: \"${input}\"`);\n 470| \n 471|         try {\n 472|             // Agentic loop\n 473|             while (true) {\n 474|                 // console.error(\"DEBUG: Calling API...\");\n 475|                 const response: any = await callApi(messages, systemPrompt);\n 476|                 // console.error(\"DEBUG: API Response received\");\n 477| \n 478|                 const contentBlocks = response.content || [];\n 479|                 const toolResults: any[] = [];\n 480| \n 481|                 for (const block of contentBlocks) {\n 482|                     if (block.type === \"text\") {\n 483|                         console.log(`\\n${CYAN}⏺${RESET} ${renderMarkdown(block.text)}`);\n 484|                         // Log assistant text\n 485|                         const asstSummary = `${new Date().toISOString()} | ASSISTANT | ${block.text.replace(/\\n/g, \"\\\\n\")}`;\n 486|                         stats.logs.push(asstSummary);\n 487|                         await appendFile(\"actions.log\", asstSummary + \"\\n\");\n 488|                     }\n 489| \n 490|                     if (block.type === \"tool_use\") {\n 491|                         const toolName = block.name;\n 492|                         const toolArgs = block.input;\n 493|                         const argPreview = JSON.stringify(Object.values(toolArgs)[0] || \"\").slice(0, 50);\n 494| \n 495|                         stats.tools[toolName