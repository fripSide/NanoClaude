|             path: \"string\",\n  40|             content: \"string\"\n  41|         },\n  42|         handler: async (args: { path: string, content: string }) => {\n  43|             await Bun.write(args.path, args.content);\n  44|             return \"ok\";\n  45|         }\n  46|     },\n  47|     edit: {\n  48|         description: \"edit a file by replacing a string\",\n  49|         params: {\n  50|             path: \"string\",\n  51|             old: \"string\",\n  52|             new: \"string\",\n  53|             all: \"boolean?\"\n  54|         },\n  55|         handler: async (args: { path: string, old: string, new: string, all?: boolean }) => {\n  56|             const path = args.path;\n  57|             const oldContent = args.old;\n  58|             const newContent = args.new;\n  59|             const all = args.all ?? false;\n  60| \n  61|             const file = Bun.file(path);\n  62|             const text = await file.text();\n  63| \n  64|             if (!text.includes(oldContent)) {\n  65|                 return \"error: old_string not found\";\n  66|             }\n  67| \n  68|             const count = text.split(oldContent).length - 1;\n  69|             if (!all && count > 1) {\n  70|                 return `error: old_string appears ${count} times, must be unique (use all=true)`;\n  71|             }\n  72| \n  73|             const replacement = all\n  74|                 ? text.replaceAll(oldContent, newContent)\n  75|                 : text.replace(oldContent, newContent);\n  76| \n  77|             await Bun.write(path, replacement);\n  78|             return \"ok\";\n  79|         }\n  80|     },\n  81|     glob: {\n  82|         description: \"glob a directory\",\n  83|         params: {\n  84|             path: \"string?\",\n  85|             pat: \"string\"\n  86|         },\n  87|         handler: async (args: { path?: string, pat: string }) => {\n  88|             const dir = args.path || \".\";\n  89|             const pattern = args.pat;\n  90| \n  91|             const globPattern = join(dir, pattern);\n  92|             const glob = new Bun.Glob(globPattern);\n  93| \n  94|             const files: { path: string, mtime: number }[] = [];\n  95| \n  96|             for await (const file of glob.scan({ cwd: \".\" })) {\n  97|                 try {\n  98|                     const stats = await stat(file);\n  99|                     if (stats.isFile()) {\n 100|                         files.push({ path: file, mtime: stats.mtimeMs });\n 101|                     }\n 102|                 } catch (e) {\n 103|                     // ignore\n 104|                 }\n 105|             }\n 106| \n 107|             files.sort((a, b) => b.mtime - a.mtime);\n 108| \n 109|             return files.map(f => f.path).join(\"\\n\") || \"none\";\n 110|         }\n 111|     },\n 112|     grep: {\n 113|         description: \"grep files in a directory\",\n 114|         params: {\n 115|             path: \"string?\",\n 116|             pat: \"string\"\n 117|         },\n 118|         handler: async (args: { path?: string, pat: string }) => {\n 119|             const pattern = args.pat;\n 120|             const regex = new RegExp(pattern);\n 121|             const hits: string[] = [];\n 122|             const searchDir = args.path || \".\";\n 123|             const glob = new Bun.Glob(\"**/*\");\n 124| \n 125|             for await (const file of glob.scan({ cwd: searchDir })) {\n 126|                 try {\n 127|                     const fullPath = join(searchDir, file);\n 128|                     const stats = await stat(fullPath);\n 129|                     if (!stats.isFile()) continue;\n 130| \n 131|                     const content = await Bun.file(fullPath).text();\n 132|                     const lines = content.split(\"\\n\");\n 133| \n 134|                     for (let i = 0; i < lines.length; i++) {\n 135|                         if (regex.test(lines[i])) {\n 136|                            