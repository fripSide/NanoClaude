 const content = [\n 446|                 `Total Requests: ${stats.requests}`,\n 447|                 `Tool Usage:`,\n 448|                 ...Object.entries(stats.tools).map(([name, count]) => `  - ${name}: ${count}`),\n 449|                 `Logs:`,\n 450|                 ...stats.logs\n 451|             ].join(\"\\n\");\n 452| \n 453|             if (path) {\n 454|                 await Bun.write(path, content);\n 455|                 console.log(`${GREEN}⏺ Stats saved to ${path}${RESET}`);\n 456|             } else {\n 457|                 console.log(`${CYAN}Stats:${RESET}\\n${content}`);\n 458|             }\n 459|             continue;\n 460|         }\n 461| \n 462|         if (input === \"/c\") {\n 463|             messages = [];\n 464|             console.log(`${GREEN}⏺ Cleared conversation${RESET}`);\n 465|             continue;\n 466|         }\n 467| \n 468|         messages.push({ role: \"user\", content: input });\n 469|         // console.error(`DEBUG: Processing input: \"${input}\"`);\n 470| \n 471|         try {\n 472|             // Agentic loop\n 473|             while (true) {\n 474|                 // console.error(\"DEBUG: Calling API...\");\n 475|                 const response: any = await callApi(messages, systemPrompt);\n 476|                 // console.error(\"DEBUG: API Response received\");\n 477| \n 478|                 const contentBlocks = response.content || [];\n 479|                 const toolResults: any[] = [];\n 480| \n 481|                 for (const block of contentBlocks) {\n 482|                     if (block.type === \"text\") {\n 483|                         console.log(`\\n${CYAN}⏺${RESET} ${renderMarkdown(block.text)}`);\n 484|                         // Log assistant text\n 485|                         const asstSummary = `${new Date().toISOString()} | ASSISTANT | ${block.text.replace(/\\n/g, \"\\\\n\")}`;\n 486|                         stats.logs.push(asstSummary);\n 487|                         await appendFile(\"act